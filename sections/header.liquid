<header class="site-header">
  <!-- Desktop left: Search + first half of nav links -->
  <div class="site-header__left">
    <button type="button" class="nav-icon-btn" aria-label="Search">
      {%- render 'icon-search' -%}
    </button>
    {%- assign left_links = section.settings.menu.links -%}
    {%- assign mid = left_links.size | divided_by: 2 -%}
    {%- for link in left_links limit: mid -%}
      <a href="{{ link.url }}" class="nav-link">{{ link.title }}</a>
    {%- endfor -%}
  </div>

  <!-- Centre: Logo -->
  <div class="site-header__center">
    <a href="/" class="site-header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 260 }}"
          alt="{{ shop.name }}"
          width="130"
          height="60"
          loading="eager"
        >
      {%- else -%}
        {%- render 'icon-logo' -%}
      {%- endif -%}
    </a>
  </div>

  <!-- Desktop right: second half of nav links + icons -->
  <div class="site-header__right">
    {%- for link in left_links offset: mid -%}
      <a href="{{ link.url }}" class="nav-link">{{ link.title }}</a>
    {%- endfor -%}
    <div class="site-header__icons">
      <button type="button" class="nav-icon-btn" aria-label="Search">
        {%- render 'icon-search' -%}
      </button>
      <a href="{{ routes.account_url }}" class="nav-icon-btn" aria-label="Account">
        {%- render 'icon-account' -%}
      </a>
      <button type="button" class="nav-icon-btn" aria-label="Wishlist">
        {%- render 'icon-wishlist' -%}
      </button>
      <a href="{{ routes.cart_url }}" class="cart-icon-wrap" aria-label="Cart ({{ cart.item_count }} items)">
        {%- render 'icon-cart' -%}
        <span class="cart-count" {% if cart.item_count == 0 %}style="display:none"{% endif %}>
          {{ cart.item_count }}
        </span>
      </a>
    </div>
  </div>

  <!-- Mobile: Cart + hamburger -->
  <div class="site-header__mobile">
    <a href="{{ routes.cart_url }}" class="cart-icon-wrap" aria-label="Cart">
      {%- render 'icon-cart' -%}
      <span class="cart-count" {% if cart.item_count == 0 %}style="display:none"{% endif %}>
        {{ cart.item_count }}
      </span>
    </a>
    <button type="button" class="hamburger-btn" aria-label="Open menu" aria-expanded="false">
      ☰
    </button>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Leave blank to use the default SVG logo."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu",
      "info": "Links are split evenly: first half on the left, second half on the right of the logo."
    }
  ]
}
{% endschema %}
