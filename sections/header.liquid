{% comment %} Scoped styles — all visual values come from Theme Editor settings {% endcomment %}
<style>
  #shopify-section-{{ section.id }} .gd-header {
    background-color: {{ section.settings.header_bg }};
    height: {{ section.settings.mobile_height }}px;
  }
  #shopify-section-{{ section.id }} .gd-nav-link,
  #shopify-section-{{ section.id }} .gd-icon-btn,
  #shopify-section-{{ section.id }} .gd-hamburger svg line,
  #shopify-section-{{ section.id }} .gd-mega-link {
    color: {{ section.settings.text_color }};
  }
  #shopify-section-{{ section.id }} .gd-hamburger svg line,
  #shopify-section-{{ section.id }} .gd-drawer__close svg line {
    stroke: {{ section.settings.text_color }};
  }
  #shopify-section-{{ section.id }} .gd-logo-img {
    height: {{ section.settings.logo_height_mobile }}px;
  }
  #shopify-section-{{ section.id }} .gd-cart-count {
    background-color: {{ section.settings.text_color }};
    color: {{ section.settings.header_bg }};
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .gd-header {
      height: {{ section.settings.desktop_height }}px;
    }
    #shopify-section-{{ section.id }} .gd-logo-img {
      height: {{ section.settings.logo_height_desktop }}px;
    }
  }
</style>

<header class="gd-header" role="banner">

  {% assign all_links = section.settings.menu.links %}
  {% assign mid        = all_links.size | divided_by: 2 %}

  {% comment %} ── DESKTOP LEFT ── {% endcomment %}
  <div class="gd-header__col gd-header__col--left">
    <button type="button" class="gd-icon-btn" aria-label="Search">
      {%- render 'icon-search' -%}
    </button>
    {%- for link in all_links limit: mid -%}
      {%- if link.links.size > 0 -%}
        <div class="gd-mega-item">
          <a href="{{ link.url }}" class="gd-nav-link">{{- link.title -}}</a>
          <div class="gd-mega-dropdown">
            <div class="gd-mega-dropdown__inner">
              {%- assign col_break = link.links.size | divided_by: 2 -%}
              <div class="gd-mega-col">
                {%- for sublink in link.links limit: col_break -%}
                  <a href="{{ sublink.url }}" class="gd-mega-link">{{ sublink.title }}</a>
                {%- endfor -%}
              </div>
              <div class="gd-mega-col">
                {%- for sublink in link.links offset: col_break -%}
                  <a href="{{ sublink.url }}" class="gd-mega-link">{{ sublink.title }}</a>
                {%- endfor -%}
              </div>
            </div>
          </div>
        </div>
      {%- else -%}
        <a href="{{ link.url }}" class="gd-nav-link">{{ link.title }}</a>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {% comment %} ── LOGO (grid col 2 on mobile, fixed center on desktop) ── {% endcomment %}
  <div class="gd-header__col gd-header__col--center">
    <a href="/" class="gd-logo-link" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 600 }}"
          alt="{{ shop.name }}"
          class="gd-logo-img"
          loading="eager"
        >
      {%- else -%}
        <img
          src="{{ 'logo.svg' | asset_url }}"
          alt="{{ shop.name }}"
          class="gd-logo-img gd-logo-img--svg"
          loading="eager"
        >
      {%- endif -%}
    </a>
  </div>

  {% comment %} ── DESKTOP RIGHT ── {% endcomment %}
  <div class="gd-header__col gd-header__col--right">
    {%- for link in all_links offset: mid -%}
      {%- if link.links.size > 0 -%}
        <div class="gd-mega-item">
          <a href="{{ link.url }}" class="gd-nav-link">{{- link.title -}}</a>
          <div class="gd-mega-dropdown gd-mega-dropdown--right">
            <div class="gd-mega-dropdown__inner">
              {%- assign col_break = link.links.size | divided_by: 2 -%}
              <div class="gd-mega-col">
                {%- for sublink in link.links limit: col_break -%}
                  <a href="{{ sublink.url }}" class="gd-mega-link">{{ sublink.title }}</a>
                {%- endfor -%}
              </div>
              <div class="gd-mega-col">
                {%- for sublink in link.links offset: col_break -%}
                  <a href="{{ sublink.url }}" class="gd-mega-link">{{ sublink.title }}</a>
                {%- endfor -%}
              </div>
            </div>
          </div>
        </div>
      {%- else -%}
        <a href="{{ link.url }}" class="gd-nav-link">{{ link.title }}</a>
      {%- endif -%}
    {%- endfor -%}
    <div class="gd-header__icons">
      <button type="button" class="gd-icon-btn" aria-label="Search">
        {%- render 'icon-search' -%}
      </button>
      <a href="{{ routes.account_url }}" class="gd-icon-btn" aria-label="Account">
        {%- render 'icon-account' -%}
      </a>
      <a href="{{ routes.cart_url }}" class="gd-icon-btn gd-cart-btn" aria-label="Cart ({{ cart.item_count }} items)">
        {%- render 'icon-cart' -%}
        <span class="gd-cart-count"{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>

  {% comment %} ── MOBILE LEFT: grid col 1 — Burger + Search ── {% endcomment %}
  <div class="gd-header__mobile-left">
    <button type="button" class="gd-icon-btn gd-hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="gd-drawer">
      <svg width="22" height="16" viewBox="0 0 22 16" fill="none" aria-hidden="true">
        <line x1="0" y1="1"  x2="22" y2="1"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="0" y1="8"  x2="22" y2="8"  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="0" y1="15" x2="22" y2="15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
    <button type="button" class="gd-icon-btn" aria-label="Search">
      {%- render 'icon-search' -%}
    </button>
  </div>

  {% comment %} ── MOBILE RIGHT: grid col 3 — Account + Cart ── {% endcomment %}
  <div class="gd-header__mobile-right">
    <a href="{{ routes.account_url }}" class="gd-icon-btn" aria-label="Account">
      {%- render 'icon-account' -%}
    </a>
    <a href="{{ routes.cart_url }}" class="gd-icon-btn gd-cart-btn" aria-label="Cart">
      {%- render 'icon-cart' -%}
      <span class="gd-cart-count"{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
    </a>
  </div>

</header>

{% comment %} ══ MOBILE DRAWER ══ {% endcomment %}
<div class="gd-drawer-backdrop" id="gd-backdrop" aria-hidden="true"></div>

<nav class="gd-drawer" id="gd-drawer" role="dialog" aria-modal="true" aria-label="Navigation" hidden>
  <div class="gd-drawer__head">
    <a href="/" class="gd-drawer__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="{{ shop.name }}" class="gd-logo-img">
      {%- else -%}
        <img src="{{ 'logo.svg' | asset_url }}" alt="{{ shop.name }}" class="gd-logo-img gd-logo-img--svg">
      {%- endif -%}
    </a>
    <button type="button" class="gd-icon-btn gd-drawer__close" aria-label="Close menu" data-close-drawer>
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <line x1="1" y1="1"  x2="17" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="17" y1="1" x2="1"  y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>
  <ul class="gd-drawer__nav" role="list">
    {%- for link in all_links -%}
      <li class="gd-drawer__item">
        {%- if link.links.size > 0 -%}
          <button type="button" class="gd-drawer__toggle" aria-expanded="false" data-accordion>
            <span>{{ link.title }}</span>
            <svg class="gd-drawer__chevron" width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
              <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="gd-drawer__sub" hidden>
            {%- for sublink in link.links -%}
              <a href="{{ sublink.url }}" class="gd-drawer__sublink">{{ sublink.title }}</a>
            {%- endfor -%}
          </div>
        {%- else -%}
          <a href="{{ link.url }}" class="gd-drawer__link">{{ link.title }}</a>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Leave blank to use the default SVG logo."
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "label": "Logo height — mobile (px)",
      "min": 24,
      "max": 64,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "logo_height_desktop",
      "label": "Logo height — desktop (px)",
      "min": 40,
      "max": 100,
      "step": 2,
      "default": 72
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu",
      "info": "Sub-links create dropdowns automatically."
    },
    {
      "type": "header",
      "content": "Layout & Colors"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Header height — mobile (px)",
      "min": 48,
      "max": 96,
      "step": 2,
      "default": 64
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Header height — desktop (px)",
      "min": 64,
      "max": 140,
      "step": 2,
      "default": 105
    },
    {
      "type": "color",
      "id": "header_bg",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & icons color",
      "default": "#171717"
    }
  ]
}
{% endschema %}
