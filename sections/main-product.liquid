<div class="product-page">

  <!-- ═══ GALERIE GAUCHE ═══════════════════════════════════════ -->
  <div class="product-page__gallery product-page__gallery--{{ section.settings.gallery_type }}">

    {%- if section.settings.gallery_type == 'scroll' -%}
      <div class="product-page__images-stack">
        {%- for image in product.images -%}
          <img
            src="{{ image | img_url: '1200x' }}"
            alt="{{ image.alt | escape }}"
            class="product-page__stack-image"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            width="{{ image.width }}"
            height="{{ image.height }}"
          >
        {%- else -%}
          <div style="aspect-ratio:4/5;background:#f0efed;width:100%;display:block;"></div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="product-page__slider-wrap" id="pd-slider-wrap">
        {%- if product.featured_image -%}
          <img
            id="product-main-image"
            src="{{ product.featured_image | img_url: '900x' }}"
            alt="{{ product.featured_image.alt | escape }}"
            class="product-page__image"
            loading="eager"
          >
        {%- else -%}
          <div class="product-page__image" style="background:#f0efed;"></div>
        {%- endif -%}
        {%- if product.images.size > 1 -%}
          <button type="button" class="product-page__slider-btn product-page__slider-btn--prev" id="pd-prev" aria-label="Image précédente">&#8592;</button>
          <button type="button" class="product-page__slider-btn product-page__slider-btn--next" id="pd-next" aria-label="Image suivante">&#8594;</button>
        {%- endif -%}
      </div>
      {%- if product.images.size > 1 -%}
        <div class="product-page__thumbnails" id="pd-thumbs">
          {%- for image in product.images -%}
            <img
              src="{{ image | img_url: '200x' }}"
              alt="{{ image.alt | escape }}"
              class="product-page__thumbnail{% if forloop.first %} is-active{% endif %}"
              data-full="{{ image | img_url: '900x' }}"
              loading="lazy"
            >
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>

  <!-- ═══ INFO DROITE ══════════════════════════════════════════ -->
  <div class="product-page__info">

    <!-- Titre + bookmark -->
    <div class="product-page__info-header">
      <h1 class="product-page__title">{{ product.title | upcase }}</h1>
      <button type="button" class="product-page__bookmark" aria-label="Sauvegarder">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z" />
        </svg>
      </button>
    </div>

    <!-- Prix -->
    <p class="product-page__price" id="product-price">
      {%- if product.price_varies -%}
        From {{ product.price_min | money }}
      {%- else -%}
        {{ product.price | money }}
      {%- endif -%}
    </p>

    <!-- Description inline -->
    {%- if product.description != blank -%}
      <div class="product-page__description">{{ product.description }}</div>
    {%- endif -%}

    <!-- Formulaire variants + ATC -->
    {%- form 'product', product, id: 'product-form' -%}
      <div class="product-page__form">

        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            <div class="product-page__option">

              {%- if option.name == 'Color' or option.name == 'Couleur' or option.name == 'Colour' -%}
                <!-- Label "Color — Tiger Camo" -->
                <label class="product-page__option-label">
                  {{ option.name }} &mdash; <span class="option-selected-value" data-option-label="{{ option.name | escape }}">{{ option.selected_value }}</span>
                </label>
                <!-- Swatches cercles -->
                <div class="product-page__color-swatches">
                  {%- for value in option.values -%}
                    {%- assign variant_image = nil -%}
                    {%- for variant in product.variants -%}
                      {%- if variant.option1 == value or variant.option2 == value or variant.option3 == value -%}
                        {%- if variant.featured_image -%}
                          {%- assign variant_image = variant.featured_image -%}
                          {%- break -%}
                        {%- endif -%}
                      {%- endif -%}
                    {%- endfor -%}
                    <button
                      type="button"
                      class="product-page__color-swatch{% if option.selected_value == value %} is-active{% endif %}"
                      data-option="{{ option.name | escape }}"
                      data-value="{{ value | escape }}"
                      title="{{ value }}"
                      {%- if variant_image -%}
                        style="background-image:url('{{ variant_image | img_url: '100x100', crop: 'center' }}')"
                      {%- endif -%}
                    ></button>
                  {%- endfor -%}
                </div>
              {%- else -%}
                <!-- Label "Size" -->
                <label class="product-page__option-label" for="option-{{ option.position }}">
                  {{ option.name }}
                </label>
                <!-- Swatches carrés -->
                {%- if section.settings.variant_style == 'buttons' -%}
                  <div class="product-page__swatches">
                    {%- for value in option.values -%}
                      <button
                        type="button"
                        class="product-page__swatch{% if option.selected_value == value %} is-active{% endif %}"
                        data-option="{{ option.name | escape }}"
                        data-value="{{ value | escape }}"
                      >{{ value }}</button>
                    {%- endfor -%}
                  </div>
                  <select
                    id="option-{{ option.position }}"
                    name="options[{{ option.name | escape }}]"
                    aria-hidden="true"
                    style="display:none;position:absolute;visibility:hidden;"
                  >
                    {%- for value in option.values -%}
                      <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                    {%- endfor -%}
                  </select>
                {%- else -%}
                  <select
                    id="option-{{ option.position }}"
                    name="options[{{ option.name | escape }}]"
                    class="product-page__select"
                  >
                    {%- for value in option.values -%}
                      <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                    {%- endfor -%}
                  </select>
                {%- endif -%}
              {%- endif -%}

            </div>
          {%- endfor -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        {%- else -%}
          <input type="hidden" name="id" value="{{ product.variants[0].id }}">
        {%- endunless -%}

        <!-- Badge inventaire "Only X left" -->
        {%- assign current_variant = product.selected_or_first_available_variant -%}
        {%- if current_variant.inventory_management == 'shopify' and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity <= 5 -%}
          <div class="product-page__inventory" id="pd-inventory">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span id="pd-inventory-text">Only {{ current_variant.inventory_quantity }} left</span>
          </div>
        {%- else -%}
          <div class="product-page__inventory" id="pd-inventory" hidden>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span id="pd-inventory-text"></span>
          </div>
        {%- endif -%}

        <!-- Bouton Add to Cart -->
        <button
          type="submit"
          class="product-page__add-btn"
          {% unless product.available %}disabled{% endunless %}
        >
          {%- if product.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
        </button>

        <!-- Buy Now (optionnel) -->
        {%- if section.settings.show_dynamic_checkout -%}
          {{ form | payment_button }}
        {%- endif -%}

      </div>
    {%- endform -%}

    <!-- Accordéon blocks -->
    {%- if section.blocks.size > 0 -%}
      <hr class="product-page__blocks-divider">
      <div class="product-page__blocks">
        {%- for block in section.blocks -%}
          <div class="product-accordion" {{ block.shopify_attributes }}>
            <button type="button" class="product-accordion__trigger" aria-expanded="false">
              <span>{{ block.settings.heading }}</span>
              <span class="product-accordion__icon">+</span>
            </button>
            <div class="product-accordion__body" hidden>
              {{ block.settings.content }}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

<!-- Mobile ATC fixe -->
<div class="product-page__mobile-atc">
  <span class="product-page__mobile-atc-price" id="pd-mobile-price">
    {%- if product.price_varies -%}From {{ product.price_min | money }}{%- else -%}{{ product.price | money }}{%- endif -%}
  </span>
  <button
    type="submit"
    form="product-form"
    class="product-page__mobile-atc-btn"
    id="pd-mobile-atc-btn"
    {% unless product.available %}disabled{% endunless %}
  >
    {%- if product.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
  </button>
</div>

<script>
  window.__variantData = {{ product.variants | json }};
</script>

<script>
(function () {
  'use strict';

  // Sticky offset = hauteur réelle du banner
  // On attend que le layout soit calculé avant de lire offsetHeight
  function setPdHeaderVar() {
    var b = document.getElementById('gd-sticky-banner');
    if (b && b.offsetHeight > 0) {
      document.documentElement.style.setProperty('--pd-header-h', b.offsetHeight + 'px');
    }
  }

  setPdHeaderVar();
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () {
      requestAnimationFrame(setPdHeaderVar);
    });
  } else {
    requestAnimationFrame(setPdHeaderVar);
  }
  // Re-measure after web fonts load — Fjalla One / Courier Prime affect banner height
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(function () { requestAnimationFrame(setPdHeaderVar); });
  }
  window.addEventListener('resize', setPdHeaderVar);

  // ── Sticky info panel (CSS sticky + JS fixed fallback) ────────────────
  // Strategy:
  //   1. CSS provides position:sticky as the primary mechanism (fast, GPU).
  //   2. JS detects whether sticky is actually working (some Shopify
  //      ancestors have overflow:hidden / contain that breaks sticky).
  //      If broken, JS switches to position:fixed using a dynamic <style>
  //      tag and a sibling .pd-info-spacer placeholder to preserve the
  //      flex slot so the gallery keeps its 55% width and doesn't expand.
  //   3. Bottom bound: when the gallery's bottom edge reaches the info
  //      panel's bottom, the panel "releases" and scrolls with the page
  //      so it never overlaps the footer / following content.
  (function () {
    var page    = document.querySelector('.product-page');
    var info    = document.querySelector('.product-page__info');
    var gallery = document.querySelector('.product-page__gallery');
    if (!page || !info || !gallery) return;

    // Dynamic <style> appended LAST in <head> so it beats every stylesheet
    // on cascade order (specificity is already (0,2,0) + !important).
    var stickyStyle = document.getElementById('pd-sticky-style');
    if (!stickyStyle) {
      stickyStyle    = document.createElement('style');
      stickyStyle.id = 'pd-sticky-style';
      document.head.appendChild(stickyStyle);
    }

    // Placeholder that holds the info panel's flex slot when it goes fixed
    var spacer = document.querySelector('.pd-info-spacer');
    if (!spacer) {
      spacer = document.createElement('div');
      spacer.className = 'pd-info-spacer';
      info.parentNode.insertBefore(spacer, info.nextSibling);
    }

    var isFixed       = false;
    var useJsFallback = null; // null = unknown, true = need JS, false = CSS works
    var snapLeft      = 0;
    var snapWidth     = 0;
    var snapDocTop    = 0;
    var rafPending    = false;

    function hdrH() {
      var b = document.getElementById('gd-sticky-banner');
      return (b && b.offsetHeight > 0) ? b.offsetHeight : 120;
    }

    // Check whether CSS position:sticky actually works for our info panel.
    // It's broken if any ancestor has overflow:hidden/auto/scroll OR a
    // contain/transform/filter/perspective that creates a containing block.
    function detectStickyBroken() {
      var el = info.parentElement;
      while (el && el !== document.body && el !== document.documentElement) {
        var cs = getComputedStyle(el);
        var ov = cs.overflow + ' ' + cs.overflowX + ' ' + cs.overflowY;
        if (/hidden|auto|scroll|clip/.test(ov)) return true;
        if (cs.contain && /(layout|paint|strict|content)/.test(cs.contain)) return true;
        el = el.parentElement;
      }
      return false;
    }

    function captureBox() {
      // Temporarily strip JS state so we measure the natural in-flow box
      var wasFixed = isFixed;
      if (wasFixed) {
        info.classList.remove('is-pd-sticky');
        spacer.style.display = 'none';
      }
      var r        = info.getBoundingClientRect();
      var scrollY  = window.scrollY || window.pageYOffset;
      snapLeft     = r.left;
      snapWidth    = r.width;
      snapDocTop   = r.top + scrollY;
      // Spacer must reserve the same vertical space the info panel uses.
      // We reserve 1px; the flex basis (.pd-info-spacer { flex: 0 0 45% })
      // handles horizontal width. Vertical space isn't actually needed
      // because flex items don't push siblings vertically — but keeping
      // a sane min-height avoids layout shift in some edge cases.
      spacer.style.minHeight = '1px';
      if (wasFixed) {
        info.classList.add('is-pd-sticky');
        spacer.style.display = 'block';
      }
    }

    function writeFixedCss(headerH) {
      // Rebuilt every tick because window resize / scrollbar may shift left.
      var maxH = 'calc(100vh - ' + headerH + 'px)';
      stickyStyle.textContent =
        '.product-page__info.is-pd-sticky{' +
          'position:fixed!important;' +
          'top:' + headerH + 'px!important;' +
          'left:' + snapLeft + 'px!important;' +
          'right:auto!important;' +
          'width:' + snapWidth + 'px!important;' +
          'max-width:' + snapWidth + 'px!important;' +
          'max-height:' + maxH + '!important;' +
          'overflow-y:auto!important;' +
          'z-index:10!important;' +
          'background:#fff!important;' +
          'box-sizing:border-box!important;' +
          'margin:0!important;' +
        '}' +
        '.pd-info-spacer{display:block!important;}';
    }

    function clearFixedCss() {
      stickyStyle.textContent = '';
    }

    function setFixed(on) {
      if (on === isFixed) return;
      if (on) {
        info.classList.add('is-pd-sticky');
        spacer.style.display = 'block';
      } else {
        info.classList.remove('is-pd-sticky');
        spacer.style.display = 'none';
        clearFixedCss();
      }
      isFixed = on;
    }

    function tick() {
      rafPending = false;
      if (window.innerWidth < 768) { setFixed(false); return; }
      // Only manage fixed mode if CSS sticky is broken
      if (useJsFallback === false) return;

      var headerH = hdrH();
      var scrollY = window.scrollY || window.pageYOffset;
      var infoH   = info.offsetHeight;
      var galRect = gallery.getBoundingClientRect();
      var galBotAbs = galRect.bottom + scrollY;

      // Activate when the panel's natural top has scrolled under the header
      var shouldFix = (scrollY + headerH) >= snapDocTop;
      // Deactivate when the gallery's bottom would push the panel's bottom
      // above what we want — release so it scrolls naturally with the page.
      var galleryEnded = galBotAbs <= (scrollY + headerH + infoH);

      if (shouldFix && !galleryEnded) {
        writeFixedCss(headerH);
        setFixed(true);
      } else {
        setFixed(false);
      }
    }

    function scheduleTick() {
      if (rafPending) return;
      rafPending = true;
      requestAnimationFrame(tick);
    }

    function init() {
      setFixed(false);
      if (window.innerWidth < 768) return;

      // Decide once whether CSS sticky will work
      if (useJsFallback === null) {
        // Force a layout / paint then test computed position
        info.offsetHeight;
        var pos = getComputedStyle(info).position;
        // If CSS sticky is supported AND no breaking ancestor, trust CSS
        var supportsSticky = (pos === 'sticky' || pos === '-webkit-sticky');
        useJsFallback = !supportsSticky || detectStickyBroken();
      }

      if (useJsFallback) {
        captureBox();
        tick();
      } else {
        // CSS sticky is doing the work — make sure spacer is hidden
        spacer.style.display = 'none';
        clearFixedCss();
      }
    }

    function reset() {
      // Full reset on resize / orientation change / late layout shifts
      useJsFallback = null;
      setFixed(false);
      init();
    }

    // ── Boot sequence ──────────────────────────────────────────────────
    // Run init ASAP, then re-run after images/fonts to catch layout shifts.
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
    window.addEventListener('load', function () { reset(); });
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(function () { reset(); });
    }

    // Re-capture when product images finish loading (they grow the gallery)
    var galleryImgs = gallery.querySelectorAll('img');
    var loadedCount = 0;
    function onImgLoad() {
      loadedCount++;
      // Recapture after each image to track the panel's correct snapDocTop.
      // Only matters for JS fallback path.
      if (useJsFallback) { captureBox(); scheduleTick(); }
    }
    for (var i = 0; i < galleryImgs.length; i++) {
      var img = galleryImgs[i];
      if (!img.complete) {
        img.addEventListener('load',  onImgLoad, { once: true });
        img.addEventListener('error', onImgLoad, { once: true });
      } else {
        loadedCount++;
      }
    }

    // Scroll + resize handlers
    window.addEventListener('scroll', scheduleTick, { passive: true });
    window.addEventListener('resize', reset);
  })();
  // ────────────────────────────────────────────────────────────────────────

  // Accordéon — icône + / −
  document.querySelectorAll('.product-accordion__trigger').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var el     = this.closest('.product-accordion');
      var body   = el.querySelector('.product-accordion__body');
      var icon   = this.querySelector('.product-accordion__icon');
      var isOpen = el.classList.contains('is-open');
      el.classList.toggle('is-open', !isOpen);
      this.setAttribute('aria-expanded', String(!isOpen));
      if (body) body.hidden = isOpen;
      if (icon) icon.textContent = isOpen ? '+' : '−';
    });
  });

  // Swatches taille → sync select caché → theme.js syncVariant
  document.querySelectorAll('.product-page__swatch').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var optName = this.dataset.option;
      var val     = this.dataset.value;
      var sel     = document.querySelector('#product-form select[name="options[' + optName + ']"]');
      if (sel) { sel.value = val; sel.dispatchEvent(new Event('change', { bubbles: true })); }
      document.querySelectorAll('.product-page__swatch[data-option="' + optName + '"]')
        .forEach(function (b) { b.classList.remove('is-active'); });
      this.classList.add('is-active');
    });
  });

  // Swatches couleur → même logique + update label "Color — [value]"
  document.querySelectorAll('.product-page__color-swatch').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var optName = this.dataset.option;
      var val     = this.dataset.value;
      var sel     = document.querySelector('#product-form select[name="options[' + optName + ']"]');
      if (sel) { sel.value = val; sel.dispatchEvent(new Event('change', { bubbles: true })); }
      document.querySelectorAll('.product-page__color-swatch[data-option="' + optName + '"]')
        .forEach(function (b) { b.classList.remove('is-active'); });
      this.classList.add('is-active');
      // Met à jour le label "Color — Tiger Camo"
      var labelSpan = document.querySelector('.option-selected-value[data-option-label="' + optName + '"]');
      if (labelSpan) labelSpan.textContent = val;
    });
  });

  // Slider
  var prevBtn  = document.getElementById('pd-prev');
  var nextBtn  = document.getElementById('pd-next');
  var thumbsEl = document.getElementById('pd-thumbs');
  var thumbs   = thumbsEl ? Array.from(thumbsEl.querySelectorAll('.product-page__thumbnail')) : [];
  var current  = 0;
  function goTo(idx) {
    if (!thumbs.length) return;
    current = (idx + thumbs.length) % thumbs.length;
    var m = document.getElementById('product-main-image');
    if (m) m.src = thumbs[current].dataset.full || thumbs[current].src;
    thumbs.forEach(function (t, i) { t.classList.toggle('is-active', i === current); });
  }
  if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); });
  if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); });
  thumbs.forEach(function (t, i) { t.addEventListener('click', function () { current = i; }); });

  // Mobile ATC — sync prix et état
  var mobileBtn     = document.getElementById('pd-mobile-atc-btn');
  var mobilePriceEl = document.getElementById('pd-mobile-price');
  var desktopPrice  = document.getElementById('product-price');
  var desktopBtn    = document.querySelector('#product-form .product-page__add-btn');
  if (desktopPrice && mobilePriceEl) {
    new MutationObserver(function () {
      mobilePriceEl.textContent = desktopPrice.textContent.trim();
    }).observe(desktopPrice, { childList: true, subtree: true, characterData: true });
  }
  if (desktopBtn && mobileBtn) {
    new MutationObserver(function () {
      mobileBtn.disabled    = desktopBtn.disabled;
      mobileBtn.textContent = desktopBtn.textContent.trim();
    }).observe(desktopBtn, { attributes: true, childList: true, characterData: true });
  }
})();
</script>

{% schema %}
{
  "name": "Product Page",
  "settings": [
    {
      "type": "select",
      "id": "gallery_type",
      "label": "Galerie",
      "options": [
        { "value": "scroll", "label": "Défilement vertical" },
        { "value": "slider", "label": "Slider" }
      ],
      "default": "scroll"
    },
    {
      "type": "select",
      "id": "variant_style",
      "label": "Style des variantes (taille)",
      "options": [
        { "value": "buttons", "label": "Boutons XS S M L" },
        { "value": "select", "label": "Dropdown" }
      ],
      "default": "buttons"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Afficher le vendeur",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Afficher le bouton Buy Now",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "artistic_details",
      "name": "Artistic Details",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Titre", "default": "Artistic Details" },
        { "type": "richtext", "id": "content", "label": "Contenu", "default": "<p>Décrivez les détails artistiques du produit ici.</p>" }
      ]
    },
    {
      "type": "material",
      "name": "Material",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Titre", "default": "Material" },
        { "type": "richtext", "id": "content", "label": "Contenu", "default": "<p>100% Cotton</p>" }
      ]
    },
    {
      "type": "care",
      "name": "Care Instructions",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Titre", "default": "Care Instructions" },
        { "type": "richtext", "id": "content", "label": "Contenu", "default": "<p>Machine wash cold. Tumble dry low.</p>" }
      ]
    },
    {
      "type": "shipping",
      "name": "Shipping & Returns",
      "limit": 1,
