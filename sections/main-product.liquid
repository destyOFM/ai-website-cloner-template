{%- comment -%} ─────────────────────────────────────────────────────────
  main-product.liquid — Product Page
  Layout : CSS Grid 50/50, left scrolls, right sticky (position:sticky)
  Mobile : single-column, scroll-snap image slider
────────────────────────────────────────────────────────────── {%- endcomment -%}

<div class="pd-layout">

  {%- comment -%} ═══ GALLERY — LEFT ═══════════════════════════════════ {%- endcomment -%}
  <div class="pd-gallery">

    <div class="pd-gallery__images" id="pd-images">
      {%- for image in product.images -%}
        <img
          class="pd-gallery__img"
          src="{{ image | image_url: width: 1400 }}"
          srcset="
            {{ image | image_url: width: 750  }} 750w,
            {{ image | image_url: width: 1100 }} 1100w,
            {{ image | image_url: width: 1400 }} 1400w"
          sizes="(max-width: 767px) 100vw, 50vw"
          alt="{{ image.alt | escape }}"
          width="{{ image.width }}"
          height="{{ image.height }}"
          loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
        >
      {%- else -%}
        <div class="pd-gallery__placeholder"></div>
      {%- endfor -%}
    </div>

    {%- if product.images.size > 1 -%}
      <div class="pd-gallery__nav">
        <button type="button" class="pd-gallery__nav-btn" id="pd-prev" aria-label="Image précédente">&#8592;</button>
        <span class="pd-gallery__nav-count" id="pd-count">1 / {{ product.images.size }}</span>
        <button type="button" class="pd-gallery__nav-btn" id="pd-next" aria-label="Image suivante">&#8594;</button>
      </div>
    {%- endif -%}

  </div>

  {%- comment -%} ═══ INFO — RIGHT (sticky) ══════════════════════════════ {%- endcomment -%}
  <div class="pd-info">

    {%- comment -%} Vendor {%- endcomment -%}
    {%- if section.settings.show_vendor and product.vendor != blank -%}
      <p class="pd-vendor">{{ product.vendor | upcase }}</p>
    {%- endif -%}

    {%- comment -%} Title + Bookmark {%- endcomment -%}
    <div class="pd-info__header">
      <h1 class="pd-title">{{ product.title | upcase }}</h1>
      <button type="button" class="pd-bookmark" aria-label="Save">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z"/>
        </svg>
      </button>
    </div>

    {%- comment -%} Price {%- endcomment -%}
    <p class="pd-price" id="pd-price">
      {%- if product.price_varies -%}
        From {{ product.price_min | money }}
      {%- else -%}
        {{ product.price | money }}
      {%- endif -%}
    </p>

    {%- comment -%} Description {%- endcomment -%}
    {%- if product.description != blank -%}
      <div class="pd-description">{{ product.description }}</div>
    {%- endif -%}

    {%- comment -%} ── Variants form ─────────────────────────────────── {%- endcomment -%}
    {%- form 'product', product, id: 'pd-form' -%}

      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}

          {%- if option.name == 'Color' or option.name == 'Couleur' or option.name == 'Colour' -%}

            <div class="pd-option">
              <div class="pd-option__label">
                {{ option.name }}
                <span class="pd-option__selected" data-option-label="{{ option.name | escape }}">{{ option.selected_value }}</span>
              </div>
              <div class="pd-swatches pd-swatches--color">
                {%- for value in option.values -%}
                  {%- assign swatch_img = nil -%}
                  {%- for variant in product.variants -%}
                    {%- if variant.option1 == value or variant.option2 == value or variant.option3 == value -%}
                      {%- if variant.featured_image -%}
                        {%- assign swatch_img = variant.featured_image -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}
                  <button
                    type="button"
                    class="pd-swatch pd-swatch--color{% if option.selected_value == value %} is-active{% endif %}"
                    data-option="{{ option.name | escape }}"
                    data-value="{{ value | escape }}"
                    title="{{ value }}"
                    {%- if swatch_img -%}
                      style="background-image:url({{ swatch_img | image_url: width: 80, height: 80, crop: 'center' }})"
                    {%- endif -%}
                  ></button>
                {%- endfor -%}
              </div>
            </div>

          {%- else -%}

            <div class="pd-option">
              <div class="pd-option__label">{{ option.name }}</div>
              {%- if section.settings.variant_style == 'buttons' -%}
                <div class="pd-swatches pd-swatches--size">
                  {%- for value in option.values -%}
                    <button
                      type="button"
                      class="pd-swatch pd-swatch--size{% if option.selected_value == value %} is-active{% endif %}"
                      data-option="{{ option.name | escape }}"
                      data-value="{{ value | escape }}"
                    >{{ value }}</button>
                  {%- endfor -%}
                </div>
                <select
                  id="pd-option-{{ option.position }}"
                  name="options[{{ option.name | escape }}]"
                  class="pd-select-hidden"
                  aria-hidden="true"
                >
                  {%- for value in option.values -%}
                    <option value="{{ value | escape }}"{% if option.selected_value == value %} selected{% endif %}>{{ value }}</option>
                  {%- endfor -%}
                </select>
              {%- else -%}
                <select
                  id="pd-option-{{ option.position }}"
                  name="options[{{ option.name | escape }}]"
                  class="pd-select"
                >
                  {%- for value in option.values -%}
                    <option value="{{ value | escape }}"{% if option.selected_value == value %} selected{% endif %}>{{ value }}</option>
                  {%- endfor -%}
                </select>
              {%- endif -%}
            </div>

          {%- endif -%}
        {%- endfor -%}

        <input type="hidden" name="id" id="pd-variant-id" value="{{ product.selected_or_first_available_variant.id }}">
      {%- else -%}
        <input type="hidden" name="id" id="pd-variant-id" value="{{ product.variants[0].id }}">
      {%- endunless -%}

      {%- comment -%} Inventory badge {%- endcomment -%}
      {%- assign cv = product.selected_or_first_available_variant -%}
      {%- assign show_inv = false -%}
      {%- if cv.inventory_management == 'shopify' and cv.inventory_quantity > 0 and cv.inventory_quantity <= 5 -%}
        {%- assign show_inv = true -%}
      {%- endif -%}
      <div class="pd-inventory" id="pd-inventory"{% unless show_inv %} hidden{% endunless %}>
        <span id="pd-inventory-text">{% if show_inv %}Only {{ cv.inventory_quantity }} left{% endif %}</span>
      </div>

      {%- comment -%} Add to Cart {%- endcomment -%}
      <button
        type="submit"
        class="pd-atc"
        id="pd-atc"
        {% unless product.available %}disabled{% endunless %}
      >
        {%- if product.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
      </button>

      {%- if section.settings.show_dynamic_checkout -%}
        {{ form | payment_button }}
      {%- endif -%}

    {%- endform -%}

    {%- comment -%} ── Accordion blocks ────────────────────────────── {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="pd-accordions">
        {%- for block in section.blocks -%}
          <div class="pd-accordion" {{ block.shopify_attributes }}>
            <button type="button" class="pd-accordion__trigger" aria-expanded="false">
              <span>{{ block.settings.heading }}</span>
              <span class="pd-accordion__icon" aria-hidden="true">+</span>
            </button>
            <div class="pd-accordion__body" hidden>
              {{ block.settings.content }}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{%- comment -%} ═══ MOBILE STICKY ATC BAR ════════════════════════════ {%- endcomment -%}
<div class="pd-bar" id="pd-bar">
  <span class="pd-bar__price" id="pd-bar-price">
    {%- if product.price_varies -%}From {{ product.price_min | money }}{%- else -%}{{ product.price | money }}{%- endif -%}
  </span>
  <button
    type="submit"
    form="pd-form"
    class="pd-bar__btn"
    id="pd-bar-btn"
    {% unless product.available %}disabled{% endunless %}
  >
    {%- if product.available -%}Add to Cart{%- else -%}Sold Out{%- endif -%}
  </button>
</div>

<script>
  window.__variantData = {{ product.variants | json }};
</script>

<script>
(function () {
  'use strict';

  // ── Header height → CSS var used by sticky panel ─────────────
  function setHeaderVar() {
    var b = document.getElementById('gd-sticky-banner');
    if (b && b.offsetHeight > 0) {
      document.documentElement.style.setProperty('--header-h', b.offsetHeight + 'px');
    }
  }
  setHeaderVar();
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setHeaderVar);
  }
  if (document.fonts && document.fonts.ready) {
    document.fonts.ready.then(function () { setHeaderVar(); });
  }
  window.addEventListener('resize', setHeaderVar);

  // ── Variant sync ──────────────────────────────────────────────
  function syncVariant() {
    var variants = window.__variantData || [];
    var form     = document.getElementById('pd-form');
    if (!form || !variants.length) return;

    var selected = [];
    form.querySelectorAll('select[name^="options["]').forEach(function (s) {
      if (s.value) selected.push(s.value);
    });
    if (!selected.length) return;

    var match = null;
    for (var i = 0; i < variants.length; i++) {
      var v    = variants[i];
      var opts = [v.option1, v.option2, v.option3].filter(function (o) { return o != null; });
      if (opts.length !== selected.length) continue;
      if (opts.every(function (o, idx) { return o === selected[idx]; })) { match = v; break; }
    }
    if (!match) return;

    // 1. Variant ID
    var idInput = document.getElementById('pd-variant-id');
    if (idInput) idInput.value = match.id;

    // 2. Price
    var price    = (match.price / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' });
    var priceEl  = document.getElementById('pd-price');
    var barPrice = document.getElementById('pd-bar-price');
    if (priceEl)  priceEl.textContent  = price;
    if (barPrice) barPrice.textContent = price;

    // 3. Inventory badge
    var invEl   = document.getElementById('pd-inventory');
    var invText = document.getElementById('pd-inventory-text');
    if (invEl) {
      var low = match.inventory_management === 'shopify'
             && match.inventory_quantity > 0
             && match.inventory_quantity <= 5;
      invEl.toggleAttribute('hidden', !low);
      if (invText) invText.textContent = low ? 'Only ' + match.inventory_quantity + ' left' : '';
    }

    // 4. ATC buttons
    var label = match.available ? 'Add to Cart' : 'Sold Out';
    [document.getElementById('pd-atc'), document.getElementById('pd-bar-btn')].forEach(function (btn) {
      if (!btn) return;
      btn.disabled    = !match.available;
      btn.textContent = label;
    });
  }

  // ── Swatch clicks ─────────────────────────────────────────────
  document.querySelectorAll('.pd-swatch').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var optName = this.dataset.option;
      var val     = this.dataset.value;

      var sel = document.querySelector('#pd-form select[name="options[' + optName + ']"]');
      if (sel) { sel.value = val; sel.dispatchEvent(new Event('change', { bubbles: true })); }

      document.querySelectorAll('.pd-swatch[data-option="' + optName + '"]')
        .forEach(function (b) { b.classList.remove('is-active'); });
      this.classList.add('is-active');

      var valueLabel = document.querySelector('.pd-option__selected[data-option-label="' + optName + '"]');
      if (valueLabel) valueLabel.textContent = val;

      syncVariant();
    });
  });

  // ── Accordion ─────────────────────────────────────────────────
  document.querySelectorAll('.pd-accordion__trigger').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var el     = this.closest('.pd-accordion');
      var body   = el.querySelector('.pd-accordion__body');
      var icon   = this.querySelector('.pd-accordion__icon');
      var isOpen = el.classList.contains('is-open');
      el.classList.toggle('is-open', !isOpen);
      this.setAttribute('aria-expanded', String(!isOpen));
      if (body) body.hidden  = isOpen;
      if (icon) icon.textContent = isOpen ? '+' : '−';
    });
  });

  // ── Mobile image slider (scroll-snap + buttons) ───────────────
  var track   = document.getElementById('pd-images');
  var prevBtn = document.getElementById('pd-prev');
  var nextBtn = document.getElementById('pd-next');
  var countEl = document.getElementById('pd-count');

  if (track) {
    var slides  = Array.from(track.querySelectorAll('.pd-gallery__img, .pd-gallery__placeholder'));
    var current = 0;

    function goTo(idx) {
      current = Math.max(0, Math.min(idx, slides.length - 1));
      slides[current].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
      if (countEl) countEl.textContent = (current + 1) + ' / ' + slides.length;
    }

    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); });

    // Sync count on native swipe
    track.addEventListener('scrollend', function () {
      var closest = 0;
      var minDiff = Infinity;
      slides.forEach(function (s, i) {
        var diff = Math.abs(s.getBoundingClientRect().left - track.getBoundingClientRect().left);
        if (diff < minDiff) { minDiff = diff; closest = i; }
      });
      current = closest;
      if (countEl) countEl.textContent = (current + 1) + ' / ' + slides.length;
    });
  }

})();
</script>

{% schema %}
{
  "name": "Product Page",
  "settings": [
    {
      "type": "select",
      "id": "variant_style",
      "label": "Style des variantes taille",
      "options": [
        { "value": "buttons", "label": "Boutons" },
        { "value": "select",  "label": "Dropdown" }
      ],
      "default": "buttons"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Afficher le vendeur",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_dynamic_checkout",
      "label": "Afficher le bouton Buy Now",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Accordion block",
      "settings": [
        { "type": "text",     "id": "heading", "label": "Titre",   "default": "Details" },
        { "type": "richtext", "id": "content", "label": "Contenu", "default": "<p>Contenu du bloc.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Page",
      "blocks": [
        { "type": "tab", "settings": { "heading": "Artistic Details" } },
        { "type": "tab", "settings": { "heading": "Material" } },
        { "type": "tab", "settings": { "heading": "Shipping & Returns" } }
      ]
    }
  ]
}
{% endschema %}
