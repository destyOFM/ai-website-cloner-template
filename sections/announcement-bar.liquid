{% comment %} Scoped styles — driven entirely by Theme Editor settings {% endcomment %}
<style>
  #shopify-section-{{ section.id }} .announcement-bar {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    min-height: {{ section.settings.bar_height }}px;
    font-size: {{ section.settings.font_size }}px;
    padding: 0 16px;
  }
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }} .announcement-bar {
      padding: 0 40px;
    }
  }
</style>

<div class="announcement-bar">
  <p class="announcement-bar__text">{{ section.settings.message }}</p>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "message",
      "label": "Message",
      "default": "FREE SHIPPING ON ORDERS $500+ (US)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#171717"
    },
    {
      "type": "range",
      "id": "bar_height",
      "label": "Bar height (px)",
      "min": 32,
      "max": 80,
      "step": 2,
      "default": 48
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size (px)",
      "min": 10,
      "max": 18,
      "step": 1,
      "default": 13
    }
  ],
  "presets": [
    { "name": "Announcement Bar" }
  ]
}
{% endschema %}
