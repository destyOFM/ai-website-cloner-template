<div class="announcement-bar">
  {%- if section.settings.top_message != blank -%}
    <div class="announcement-bar__top">{{ section.settings.top_message }}</div>
  {%- endif -%}

  {%- if section.settings.bottom_message != blank -%}
    <div class="announcement-bar__bottom">
      <span class="announcement-bar__message">{{ section.settings.bottom_message }}</span>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "top_message",
      "label": "Top bar message (desktop only)",
      "default": "Free shipping to Canada on all orders above CA$980.00"
    },
    {
      "type": "text",
      "id": "bottom_message",
      "label": "Main bar message",
      "default": "FREE SHIPPING ON ORDERS $500+ (US)"
    }
  ]
}
{% endschema %}
