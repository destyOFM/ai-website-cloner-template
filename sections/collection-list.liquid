<section class="collection-banner">
  {%- for block in section.blocks -%}
    {%- assign coll = collections[block.settings.collection] -%}
    {%- assign href = coll.url | default: block.settings.link | default: '#' -%}
    <a href="{{ href }}" class="collection-banner__item" {{ block.shopify_attributes }}>
      <div class="collection-banner__image-wrap">
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | img_url: '1200x' }}"
            srcset="
              {{ block.settings.image | img_url: '768x' }} 768w,
              {{ block.settings.image | img_url: '1200x' }} 1200w
            "
            sizes="(min-width: 768px) 50vw, 100vw"
            alt="{{ block.settings.image.alt | escape | default: block.settings.title }}"
            class="collection-banner__image"
            loading="lazy"
          >
        {%- else -%}
          <div class="collection-banner__placeholder"></div>
        {%- endif -%}
      </div>
      <div class="collection-banner__label">
        <span class="collection-banner__title">{{ block.settings.title }}</span>
      </div>
    </a>
  {%- endfor -%}
</section>

{% schema %}
{
  "name": "Collection List",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "collection_item",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection (sets the link)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "COLLECTION NAME"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Fallback link (if no collection set)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection List",
      "blocks": [
        { "type": "collection_item" },
        { "type": "collection_item" }
      ]
    }
  ]
}
{% endschema %}
