<div class="hero-slideshow">
  {%- if section.settings.image_desktop != blank -%}
    <img
      src="{{ section.settings.image_desktop | img_url: '1920x' }}"
      srcset="
        {{ section.settings.image_desktop | img_url: '768x' }} 768w,
        {{ section.settings.image_desktop | img_url: '1440x' }} 1440w,
        {{ section.settings.image_desktop | img_url: '1920x' }} 1920w
      "
      sizes="100vw"
      alt="{{ section.settings.image_desktop.alt | escape }}"
      class="hero-slideshow__img hero-slideshow__img--desktop"
      loading="eager"
      fetchpriority="high"
    >
  {%- else -%}
    <div class="hero-slideshow__placeholder hero-slideshow__img--desktop">
      Add hero image in Theme Editor
    </div>
  {%- endif -%}

  {%- if section.settings.image_mobile != blank -%}
    <img
      src="{{ section.settings.image_mobile | img_url: '800x' }}"
      alt="{{ section.settings.image_mobile.alt | escape }}"
      class="hero-slideshow__img hero-slideshow__img--mobile"
      loading="eager"
      fetchpriority="high"
    >
  {%- elsif section.settings.image_desktop != blank -%}
    <img
      src="{{ section.settings.image_desktop | img_url: '800x' }}"
      alt="{{ section.settings.image_desktop.alt | escape }}"
      class="hero-slideshow__img hero-slideshow__img--mobile"
      loading="eager"
    >
  {%- else -%}
    <div class="hero-slideshow__placeholder hero-slideshow__img--mobile">
      Add hero image in Theme Editor
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Hero Slideshow",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image (recommended: 1920×988px)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image (recommended: 800×500px)"
    }
  ],
  "presets": [
    {
      "name": "Hero Slideshow"
    }
  ]
}
{% endschema %}
